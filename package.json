{
  "name": "kessan-tantei",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "backfill:history": "tsx scripts/backfill-zero-financials.ts",
    "backfill:edinet-all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/run-edinet-backfill-safe.ts --days=400 --continue-on-error",
    "backfill:news-all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/backfill-all-market-news.ts",
    "backfill:news-all-markets-full": "NEWS_PER_COMPANY=5 DOTENV_CONFIG_PATH=.env.local tsx scripts/backfill-all-market-news.ts --restart",
    "retry:news-missing": "DOTENV_CONFIG_PATH=.env.local tsx scripts/backfill-all-market-news.ts --missing-only",
    "retry:edinet-failures": "DOTENV_CONFIG_PATH=.env.local tsx scripts/retry-edinet-failures.ts",
    "classify:all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/classify-all-market-special-securities.ts",
    "repair:market-memberships": "DOTENV_CONFIG_PATH=.env.local tsx scripts/repair-market-memberships.ts",
    "repair:financial-data": "tsx scripts/repair-financial-anomalies.ts",
    "repair:core-financial-data": "tsx scripts/repair-core-financial-data.ts",
    "repair:financial-sector-data": "DOTENV_CONFIG_PATH=.env.local tsx scripts/reprocess-financial-sector-data.ts",
    "sync:jpx-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/sync-jpx-all-markets.ts && DOTENV_CONFIG_PATH=.env.local tsx scripts/repair-market-memberships.ts",
    "sync:edinet-daily": "DOTENV_CONFIG_PATH=.env.local tsx scripts/sync-daily-edinet.ts",
    "complete:all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/run-all-markets-completion.ts",
    "complete:all-markets:repair": "DOTENV_CONFIG_PATH=.env.local tsx scripts/run-all-markets-completion.ts --with-repairs",
    "complete:all-markets:no-sync": "DOTENV_CONFIG_PATH=.env.local tsx scripts/run-all-markets-completion.ts --skip-sync",
    "audit:financial-data": "tsx scripts/audit-financial-data.ts",
    "audit:financial-sector-data": "DOTENV_CONFIG_PATH=.env.local tsx scripts/audit-financial-sector-data.ts",
    "diagnose:financial-sector-tags": "DOTENV_CONFIG_PATH=.env.local tsx scripts/diagnose-financial-sector-tags.ts",
    "audit:financial-integrity": "tsx scripts/audit-financial-integrity.ts",
    "audit:history-periods": "tsx scripts/audit-history-periods.ts",
    "audit:phase1-all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/audit-phase1-all-markets.ts",
    "audit:phase2-market-master": "DOTENV_CONFIG_PATH=.env.local tsx scripts/audit-phase2-market-master.ts",
    "audit:all-markets-data": "DOTENV_CONFIG_PATH=.env.local tsx scripts/audit-all-markets-data.ts",
    "audit:phase4": "tsx scripts/audit-phase4.ts",
    "audit:phase7": "tsx scripts/audit-phase7.ts",
    "audit:phase8": "tsx scripts/audit-phase8.ts",
    "audit:phase9": "tsx scripts/audit-phase9.ts",
    "audit:phase10": "tsx scripts/audit-phase10.ts",
    "audit:phase16-all-markets": "DOTENV_CONFIG_PATH=.env.local tsx scripts/audit-phase16-all-markets.ts",
    "audit:release": "tsx scripts/audit-release.ts",
    "audit:stripe": "tsx scripts/audit-stripe.ts",
    "audit:seo": "tsx scripts/audit-seo.ts",
    "audit:final": "tsx scripts/audit-final.ts",
    "inspect:duplicate-tickers": "tsx scripts/inspect-duplicate-tickers.ts",
    "cleanup:duplicate-tickers": "tsx scripts/cleanup-duplicate-tickers.ts",
    "normalize:history-periods": "tsx scripts/normalize-history-periods.ts",
    "check:fiscal-periods": "tsx scripts/check-fiscal-period-extraction.ts",
    "check:financial-sector-parser": "tsx scripts/check-financial-sector-parser.ts",
    "audit:market-order": "tsx scripts/audit-market-display-order.ts",
    "audit:pro-boundaries": "tsx scripts/audit-pro-boundaries.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.9",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "adm-zip": "^0.5.17",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.9.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.16.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tsx": "^4.22.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
